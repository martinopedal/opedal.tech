{
  "$schema": "https://raw.githubusercontent.com/streetsidesoftware/cspell/main/cspell.schema.json",
  "version": "0.2",
  "language": "en-US",
  "dictionaries": [
    "en_us",
    "softwareTerms",
    "typescript",
    "html",
    "css",
    "fonts",
    "filetypes",
    "npm",
    "node"
  ],
  "ignorePaths": [
    "dist/**",
    "node_modules/**",
    ".git/**",
    "cv/architect/build/**",
    "cv/templates/**",
    "*.lock",
    "package-lock.json",
    "*.pdf",
    "**/__pycache__/**",
    "*.j2.from-git",
    "**/*.svg"
  ],
  "ignoreRegExpList": [
    "/(https?:\\/\\/[^\\s]+)/gi",
    "/#[0-9a-fA-F]{3,8}\\b/g",
    "/```[\\s\\S]*?```/g",
    "/`[^`]+`/g",
    "/\\b(class|id|href|src|alt|rel|type|name|content|property|itemtype|itemprop)\\s*=\\s*[\"'][^\"']*[\"']/gi",
    "/^---[\\s\\S]*?^---/gm"
  ],
