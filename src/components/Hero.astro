---
import { link } from '../utils/link';
---
<header id="hero">
  <div class="hero-inner">
    <h1>Martin Opedal</h1>
    <p class="hero-anchor">
      Lead Cloud Solution Architect at Microsoft. 15 years building Azure platforms 
      for regulated Nordic enterprises. Patterns, code, and lessons here.
    </p>
    <p class="trust-signals">
      15 years in cloud · Azure Solutions Architect Expert · Speaker at NIC + Microsoft events · 
      Open source on <a href="https://github.com/martinopedal" target="_blank" rel="noopener noreferrer">GitHub</a> · 
      Based in Oslo
    </p>
    <div class="hero-cta">
      <a class="btn btn-primary" href={link('work')}>See selected work</a>
      <a class="btn btn-ghost" href="mailto:hello@opedal.tech">Email me</a>
    </div>
  </div>
</header>
