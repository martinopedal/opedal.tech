---
import { link } from '../utils/link';
const currentPath = Astro.url.pathname;
const isActive = (prefix: string) => {
  if (prefix === '/') return currentPath === '/' || currentPath === '';
  return currentPath === prefix || currentPath.startsWith(prefix + '/') || currentPath === prefix.replace(/\/$/, '');
};
---

<nav class="site-nav">
  <a class="nav-brand" href={link('')}>opedal.tech</a>

  <!--
    CSS-only hamburger menu.
    The hidden checkbox acts as a toggle; the label triggers it.
    No JavaScript needed - works with prefers-reduced-motion.
  -->
  <input type="checkbox" id="nav-toggle" class="nav-toggle" />
  <label for="nav-toggle" class="hamburger" aria-label="Toggle navigation">
    <span></span>
    <span></span>
    <span></span>
  </label>

  <ul class="nav-links" role="list">
    <li><a href={link('')} aria-current={isActive('/') ? 'page' : undefined}>Home</a></li>
    <li><a href={link('work')} aria-current={isActive('/work') ? 'page' : undefined}>Work</a></li>
    <li><a href={link('about')} aria-current={isActive('/about') ? 'page' : undefined}>About</a></li>
    <li><a href={link('blog')} aria-current={isActive('/blog') ? 'page' : undefined}>Blog</a></li>
    <li><a href={link('contact')} aria-current={isActive('/contact') ? 'page' : undefined}>Contact</a></li>
  </ul>
</nav>

