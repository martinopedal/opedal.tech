---
import { link } from '../utils/link';
const currentPath = Astro.url.pathname;
---

<nav class="site-nav">
  <a class="nav-brand" href={link('')}>opedal.tech</a>

  <!--
    CSS-only hamburger menu.
    The hidden checkbox acts as a toggle; the label triggers it.
    No JavaScript needed - works with prefers-reduced-motion.
  -->
  <input type="checkbox" id="nav-toggle" class="nav-toggle" />
  <label for="nav-toggle" class="hamburger" aria-label="Toggle navigation">
    <span></span>
    <span></span>
    <span></span>
  </label>

  <ul class="nav-links" role="list">
    <li><a href={link('')}>Home</a></li>
    <li><a href={link('work')}>Work</a></li>
    <li><a href={link('cv')}>CV</a></li>
    <li><a href={link('blog')} class={currentPath.startsWith('/blog') ? 'nav-blog' : ''}>Blog</a></li>
    <li><a href={link('contact')} class={currentPath.startsWith('/contact') ? 'nav-contact-active' : ''}>Contact</a></li>
  </ul>
</nav>
