---
import BaseLayout from './BaseLayout.astro';
import Nav from '../components/Nav.astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  tags: string[];
  canonicalUrl?: string;
}

const { title, description, pubDate, updatedDate, tags, canonicalUrl } =
  Astro.props;

const formattedPub = pubDate.toLocaleDateString('en-GB', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const formattedUpdated = updatedDate?.toLocaleDateString('en-GB', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

// Article schema for blog posts. Stacks on top of the sitewide Person schema
// emitted by BaseLayout. <script type="application/ld+json"> is CSP-exempt.
const articleUrl = canonicalUrl ?? Astro.url.href;
const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  url: articleUrl,
  datePublished: pubDate.toISOString(),
  ...(updatedDate ? { dateModified: updatedDate.toISOString() } : {}),
  inLanguage: 'en',
  keywords: tags.join(', '),
  author: {
    '@type': 'Person',
    name: 'Martin Opedal',
    url: 'https://opedal.tech',
  },
  publisher: {
    '@type': 'Person',
    name: 'Martin Opedal',
    url: 'https://opedal.tech',
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': articleUrl,
  },
};
---

<BaseLayout
  title={`${title} — opedal.tech`}
  description={description}
  canonicalUrl={canonicalUrl}
  ogType="article"
>
  <Fragment slot="head-extra">
    <meta property="article:published_time" content={pubDate.toISOString()} />
    {updatedDate && (
      <meta property="article:modified_time" content={updatedDate.toISOString()} />
    )}
    <meta property="article:author" content="Martin Opedal" />
    {tags.map((tag) => (
      <meta property="article:tag" content={tag} />
    ))}
    <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  </Fragment>

  <Nav />

  <nav class="post-nav">
    <a href="/blog">&larr; All posts</a>
  </nav>

  <header class="post-header">
    <div class="post-meta">
      <time datetime={pubDate.toISOString()}>{formattedPub}</time>
      {updatedDate && (
        <span>&middot; Updated <time datetime={updatedDate.toISOString()}>{formattedUpdated}</time></span>
      )}
    </div>
    <h1>{title}</h1>
    {tags.length > 0 && (
      <div class="post-tags">
        {tags.map((tag) => <span class="blog-tag">{tag}</span>)}
      </div>
    )}
  </header>

  <article class="post-content prose">
    <slot />
  </article>
</BaseLayout>
