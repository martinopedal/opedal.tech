---
import '../styles/global.css';
import { safeJsonLd } from '../utils/jsonld';

interface Props {
  title: string;
  description: string;
  canonicalUrl?: string;
  ogImage?: string;
  ogImageAlt?: string;
  ogType?: 'website' | 'article';
}

const {
  title,
  description,
  canonicalUrl = Astro.url.href,
  ogImage = '/og-default.png',
  ogImageAlt = 'opedal.tech, Martin Opedal, Lead Cloud Solution Architect at Microsoft',
  ogType = 'website',
} = Astro.props;

// Site verification tokens from environment variables (GitHub Actions repo variables)
// When Martin adds PUBLIC_GOOGLE_SITE_VERIFICATION and PUBLIC_BING_SITE_VERIFICATION
// as repo variables, next deploy auto-verifies the site without code changes.
const gscToken = import.meta.env.PUBLIC_GOOGLE_SITE_VERIFICATION;
const bingToken = import.meta.env.PUBLIC_BING_SITE_VERIFICATION;

// og-default.png ships at 1200x630 (the standard OG aspect). Custom per-page
// overrides should match these dimensions or override the meta tags below.
const ogImageUrl = new URL(ogImage, Astro.site).toString();
const currentYear = new Date().getFullYear();

// Sitewide WebSite schema. Helps search engines and AI scrapers identify the
// site as a single entity, which is required for Google's Knowledge Graph
// matching alongside the Person schema below.
const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  '@id': 'https://opedal.tech/#website',
  name: 'opedal.tech',
  alternateName: 'Martin Opedal',
  url: 'https://opedal.tech/',
  inLanguage: ['en', 'nb'],
  author: {
    '@id': 'https://opedal.tech/#person',
  },
  publisher: {
    '@id': 'https://opedal.tech/#person',
  },
};

// Comprehensive Person schema. Lives in BaseLayout so every page emits it.
// JSON-LD <script type="application/ld+json"> blocks are CSP-exempt
// because the browser parses them as data, not executable script.
const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  '@id': 'https://opedal.tech/#person',
  name: 'Martin Opedal',
  givenName: 'Martin',
  familyName: 'Opedal',
  url: 'https://opedal.tech',
  image: ogImageUrl,
  email: 'mailto:hello@opedal.tech',
  jobTitle: 'Lead Cloud Solution Architect',
  worksFor: {
    '@type': 'Organization',
    name: 'Microsoft',
    url: 'https://www.microsoft.com',
  },
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Oslo',
    addressCountry: 'NO',
  },
  nationality: {
    '@type': 'Country',
    name: 'Norway',
  },
  sameAs: [
    'https://www.linkedin.com/in/martin-opedal',
    'https://github.com/martinopedal',
    'https://x.com/MartinOpedal',
    'https://www.instagram.com/martinopedal',
    'https://www.facebook.com/opedalmartin',
  ],
  knowsLanguage: ['en', 'nb'],
  knowsAbout: [
    'Microsoft Azure',
    'Azure Landing Zones',
    'Azure Kubernetes Service',
    'Kubernetes',
    'AKS',
    'Terraform',
    'Bicep',
    'Infrastructure as Code',
    'Cloud Security',
    'Sovereign Cloud',
    'Platform Engineering',
    'GitHub Actions',
    'GitHub Copilot',
    'Azure Policy',
    'Azure Resource Graph',
    'Azure AI Foundry',
    'Cloud Architecture',
    'DevOps',
    'Well-Architected Framework',
  ],
  award: [
    'Microsoft Certified: Cybersecurity Architect Expert',
    'Microsoft Certified: Azure Solutions Architect Expert',
    'Microsoft Certified: DevOps Engineer Expert',
    'Microsoft 365 Certified: Administrator Expert',
    'Microsoft Certified: Azure Network Engineer Associate',
    'Microsoft Certified: Azure Administrator Associate',
    'Microsoft Certified: Azure Security Engineer Associate',
    'HashiCorp Certified: Terraform Associate',
    'ITIL Foundation',
  ],
  description:
    'Lead Cloud Solution Architect at Microsoft Norway. Designs Azure Landing Zones, AKS platforms, and AI infrastructure for regulated and sovereign workloads. Writes and speaks on Terraform, Bicep, Kubernetes, and platform engineering. Open-source contributor to Azure Verified Modules and the ALZ Terraform module.',
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="author" content="Martin Opedal" />
    <meta name="theme-color" content="#14110f" />
    <meta name="generator" content={Astro.generator} />

    <!-- Site verification (env-driven, no code changes needed when tokens added) -->
    {gscToken && <meta name="google-site-verification" content={gscToken} />}
    {bingToken && <meta name="msvalidate.01" content={bingToken} />}

    <!-- CSP: no inline scripts, no external CDN, same-origin only. JSON-LD is exempt. -->
    <meta
      http-equiv="Content-Security-Policy"
      content="default-src 'self'; script-src 'none'; script-src-elem 'self'; style-src 'self'; style-src-attr 'none'; img-src 'self' data:; font-src 'self'; connect-src 'none'; media-src 'none'; object-src 'none'; frame-src 'none'; child-src 'none'; worker-src 'none'; manifest-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'; upgrade-insecure-requests"
    />

    <!--
      Permissions-Policy: deny every browser capability the site does not need.
      `fullscreen=(self)` is harmless and left allowed; everything else is denied.
      NB: <meta http-equiv> is honoured by Chromium-based browsers; Firefox and
      Safari ignore it (they require an HTTP response header, which GitHub Pages
      does not let us set). Ship it as defense-in-depth for the majority of
      visitors and revisit if Pages ever supports header configuration.
    -->
    <meta
      http-equiv="Permissions-Policy"
      content="accelerometer=(), autoplay=(), browsing-topics=(), camera=(), display-capture=(), encrypted-media=(), fullscreen=(self), geolocation=(), gyroscope=(), interest-cohort=(), magnetometer=(), microphone=(), midi=(), payment=(), picture-in-picture=(), publickey-credentials-get=(), screen-wake-lock=(), sync-xhr=(), usb=(), web-share=(), xr-spatial-tracking=()"
    />

    <!-- Referrer-Policy: do not leak any referrer (no analytics need it). -->
    <meta name="referrer" content="no-referrer" />

    <!-- Canonical & Open Graph -->
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="opedal.tech" />
    <meta property="og:locale" content="en_US" />
    {ogImageUrl && <meta property="og:image" content={ogImageUrl} />}
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={ogImageAlt} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={ogImageAlt} />

    <!-- RSS feed discovery -->
    <link
      rel="alternate"
      type="application/rss+xml"
      title="opedal.tech blog"
      href="/rss.xml"
    />

    <!-- IndieWeb identity verification -->
    <link rel="me" href="https://www.linkedin.com/in/martin-opedal" />
    <link rel="me" href="https://github.com/martinopedal" />
    <link rel="me" href="mailto:hello@opedal.tech" />

    <!-- Font preload -->
    <link rel="preload" as="font" type="font/woff2" href="/fonts/jetbrains-mono-variable.woff2" crossorigin />

    <!-- Sitewide Person schema for search engines and AI scrapers. -->
    <script type="application/ld+json" set:html={safeJsonLd(personSchema)} />

    <!-- Sitewide WebSite schema for search engines (Knowledge Graph signals). -->
    <script type="application/ld+json" set:html={safeJsonLd(websiteSchema)} />

    <slot name="head-extra" />

    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <slot />
    <footer>
      <div class="container">
        <p class="footer-line">
          &copy; {currentYear} Martin Opedal &middot; Built with Astro
        </p>
        <ul class="footer-links" role="list">
          <li>
            <a
              href="mailto:hello@opedal.tech"
              aria-label="Email Martin Opedal at hello@opedal.tech">Email</a>
          </li>
          <li>
            <a
              href="https://github.com/martinopedal"
              target="_blank"
              rel="me noopener noreferrer"
              aria-label="Martin Opedal on GitHub">GitHub</a>
          </li>
          <li>
            <a
              href="https://www.linkedin.com/in/martin-opedal"
              target="_blank"
              rel="me noopener noreferrer"
              aria-label="Martin Opedal on LinkedIn">LinkedIn</a>
          </li>
          <li>
            <a
              href="https://github.com/martinopedal/opedal.tech"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="View source code on GitHub">Source</a>
          </li>
        </ul>
      </div>
    </footer>
  </body>
</html>
