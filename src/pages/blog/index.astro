---
import { getCollection } from 'astro:content';
import { link } from '../../utils/link';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import { safeJsonLd } from '../../utils/jsonld';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const posts = allPosts.sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
);

// Breadcrumb schema for the blog index. SERP-friendly trail: Home -> Blog.
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Home',
      item: 'https://opedal.tech/',
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'Blog',
      item: 'https://opedal.tech/blog/',
    },
  ],
};
---

<BaseLayout
  title="Blog · opedal.tech"
  description="Field notes on Azure Landing Zones, AKS Automatic with Terraform, IaC security patterns, GitHub Copilot CLI, and AI-assisted platform engineering."
>
  <Fragment slot="head-extra">
    <script type="application/ld+json" set:html={safeJsonLd(breadcrumbSchema)} />
  </Fragment>

  <Nav />

  <div class="blog-hero">
    <h1>Blog</h1>
    <p>Field notes on Azure Landing Zones, AKS Automatic with Terraform, IaC security, and AI-assisted platform engineering.</p>
  </div>

  <main id="main-content" tabindex="-1">
    {posts.length === 0 ? (
      <div class="blog-empty">
        <p>No posts yet. Check back soon.</p>
      </div>
    ) : (
      <div class="blog-list">
        {posts.map((post) => {
          const formattedDate = post.data.pubDate.toLocaleDateString('en-GB', {
            year: 'numeric',
            month: 'long',
            day: 'numeric',
          });
          return (
            <a href={link(`blog/${post.slug}`)} class="blog-card">
              <div class="blog-card-meta">
                <time class="blog-date" datetime={post.data.pubDate.toISOString()}>
                  {formattedDate}
                </time>
                {post.data.tags.map((tag) => (
                  <span class="blog-tag">{tag}</span>
                ))}
              </div>
              <h2>{post.data.title}</h2>
              <p class="blog-excerpt">{post.data.description}</p>
            </a>
          );
        })}
      </div>
    )}
  </main>
</BaseLayout>
