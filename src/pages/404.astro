---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';

const title = '404 · Page not found · opedal.tech';
const description = 'The page you were looking for does not exist on opedal.tech.';
---
<BaseLayout title={title} description={description}>
  <Nav />
  <main id="main-content" class="not-found-page" tabindex="-1">
    <section class="container not-found">
      <p class="eyebrow">404</p>
      <h1>This page does not exist.</h1>
      <p class="lead">
        The link you followed is broken, or the page has moved. Try one of these instead:
      </p>
      <ul class="not-found-links" role="list">
        <li><a href="/">Home</a> &mdash; the main page</li>
        <li><a href="/work/">Work</a> &mdash; what I architect day to day</li>
        <li><a href="/cv/">CV</a> &mdash; long-form CV</li>
        <li><a href="/blog/">Blog</a> &mdash; recent posts</li>
        <li><a href="/contact/">Contact</a> &mdash; how to reach me</li>
      </ul>
      <p class="muted">
        If you reached this from a link inside opedal.tech, please
        <a href="https://github.com/martinopedal/opedal.tech/issues/new?labels=bug%2Csquad&amp;title=fix%3A%20broken%20link">open an issue on GitHub</a>.
      </p>
    </section>
  </main>
</BaseLayout>
